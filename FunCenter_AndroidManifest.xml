<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="edu.uic.cs478.s2026.funcenter">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="FunCenter"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The bound service exposed to other apps -->
        <service
            android:name=".FunCenterService"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="edu.uic.cs478.s2026.funcenter.aidl.IFunCenterService" />
            </intent-filter>
        </service>

    </application>

</manifest>
